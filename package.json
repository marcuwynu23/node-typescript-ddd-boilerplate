{
  "name": "node-typescript-ddd-boilerplate",
  "version": "2.0.0",
  "description": "Enterprise-ready Node.js + TypeScript boilerplate using Domain-Driven Design (DDD) and Clean Architecture",
  "main": "dist/index.js",
  "scripts": {
    "build": "node build.js",
    "start": "node dist/index.js",
    "dev": "nodemon --watch src --watch .env --exec tsx src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "prepare": "husky",
    "commit": "git-cz"
  },
  "lint-staged": {
    "*.{js,ts,json}": [
      "biome check --write ."
    ],
    "*.{js,ts}": [
      "biome check --write ."
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.215.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@scalar/express-api-reference": "^0.9.18",
    "@types/dotenv": "^6.1.1",
    "dotenv": "^17.4.2",
    "express": "^4.22.2",
    "helmet": "^8.1.0",
    "mongoose": "^9.6.2",
    "pino": "^9.9.0",
    "pino-http": "^10.5.0",
    "prom-client": "^15.1.3"
  },
  "engines": {
    "node": ">=18.20.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.10.0",
    "@types/supertest": "^6.0.3",
    "commitizen": "^4.3.1",
    "cross-env": "^10.1.0",
    "cz-conventional-changelog": "^3.3.0",
    "dotenv-cli": "^11.0.0",
    "esbuild": "^0.25.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.4.0",
    "pino-pretty": "^13.1.1",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "tsx": "^4.21.0",
    "typescript": "^5.3.2"
  }
}
